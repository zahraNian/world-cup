# Copy to .env for local development

# Backend API host (no protocol)
VITE_ABR_URL=back-stage1.nipoto.pro

# Override public domain (optional, inferred from VITE_ABR_URL if unset)
# VITE_PUBLIC_DOMAIN=nipoto.com

# Login port for localhost only (optional, default: 8081)
# VITE_LOGIN_PORT=8081

# Brand / company (nipoto | tetherland) — set per deployment, no theme switcher in UI
VITE_BRAND=nipoto

# Optional per-deployment overrides (defaults live in config/brands.ts)
# VITE_APP_TITLE=کمپین پیش‌بینی جام جهانی ۲۰۲۶
# VITE_EXCHANGE_NAME=نیپوتو
# VITE_EXCHANGE_URL=https://nipoto.com
# VITE_LOGO_URL=/brands/nipoto-logo.svg
